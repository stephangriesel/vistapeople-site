---
---
<div id="password-overlay" class="fixed inset-0 z-[9999] bg-white dark:bg-dark flex flex-col items-center justify-center px-4">
  <div class="bg-white dark:bg-dark-2 rounded-lg shadow-lg max-w-md w-full p-8 text-center border border-stroke dark:border-dark-3">
    <div class="mb-6 flex justify-center">
      <h2 class="text-3xl font-bold text-dark dark:text-white">Blog Preview</h2>
    </div>
    <p class="text-base text-body-color dark:text-dark-6 mb-8">Please enter the access password requested by your agency to preview this content.</p>
    
    <div class="mb-5 text-left">
      <input 
        type="password" 
        id="preview-password" 
        class="w-full rounded-md border border-transparent bg-[#f5f5f5] dark:bg-[#2C303B] py-3 px-5 text-dark dark:text-white outline-none focus:border-primary focus-visible:shadow-none" 
        placeholder="Enter password..." 
      />
    </div>
    <div id="password-error" class="hidden text-red-500 mb-5 text-sm font-medium text-left">Incorrect password. Please try again.</div>
    
    <button id="preview-submit" class="w-full rounded-md bg-primary py-3 px-5 text-white transition hover:bg-blue-dark font-semibold cursor-pointer">
      Unlock Preview
    </button>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('password-overlay');
    const input = document.getElementById('preview-password');
    const submitBtn = document.getElementById('preview-submit');
    const errorMsg = document.getElementById('password-error');
    
    // Standard preview password
    const CORRECT_PASSWORD = 'vista';
    
    // Check if already authenticated this session
    if (sessionStorage.getItem('blog_authenticated') === 'true') {
      if (overlay) overlay.remove();
      return;
    }
    
    // Lock background scroll when the overlay is visible
    document.body.style.overflow = 'hidden';
    
    const checkPassword = () => {
      if (input.value === CORRECT_PASSWORD || input.value === 'Vista' || input.value === 'VISTA') {
        sessionStorage.setItem('blog_authenticated', 'true');
        document.body.style.overflow = '';
        overlay.remove();
      } else {
        errorMsg.classList.remove('hidden');
        input.value = '';
        input.focus();
      }
    };
    
    if (submitBtn) submitBtn.addEventListener('click', checkPassword);
    if (input) {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') checkPassword();
      });
      // Auto-focus on load
      setTimeout(() => input.focus(), 100);
    }
  });
</script>
